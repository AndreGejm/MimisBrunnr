{
  "name": "@multi-agent-brain/workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -b tsconfig.json --pretty false",
    "cli": "pnpm --filter @multi-agent-brain/brain-cli cli",
    "api": "pnpm --filter @multi-agent-brain/brain-api serve",
    "mcp": "pnpm --filter @multi-agent-brain/brain-mcp serve",
    "test:e2e": "pnpm build && node --test tests/e2e/service-boundaries-and-regression.test.mjs tests/e2e/transport-adapters.test.mjs tests/e2e/mcp-adapter.test.mjs tests/e2e/local-model-providers.test.mjs",
    "test": "pnpm test:e2e",
    "docker:up": "docker compose -f docker/compose.local.yml up --build",
    "docker:down": "docker compose -f docker/compose.local.yml down --volumes"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
