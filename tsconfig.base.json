{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@mimir/contracts": ["packages/contracts/src/index.ts"],
      "@mimir/contracts/*": ["packages/contracts/src/*"],
      "@mimir/domain": ["packages/domain/src/index.ts"],
      "@mimir/domain/*": ["packages/domain/src/*"],
      "@mimir/application": ["packages/application/src/index.ts"],
      "@mimir/application/*": ["packages/application/src/*"],
      "@mimir/orchestration": ["packages/orchestration/src/index.ts"],
      "@mimir/orchestration/*": ["packages/orchestration/src/*"],
      "@mimir/infrastructure": ["packages/infrastructure/src/index.ts"],
      "@mimir/infrastructure/*": ["packages/infrastructure/src/*"]
    }
  }
}
