MAB_NODE_ENV=development
# Display name for release metadata. MAB_* remains the compatibility prefix.
MIMIR_APPLICATION_NAME=mimir
MAB_RELEASE_VERSION=1.0.1
# Optional Git-centric release metadata for tagged builds and traceable rollouts:
# MAB_GIT_TAG=v1.0.1
# MAB_GIT_COMMIT=0123456789abcdef
# MAB_RELEASE_CHANNEL=tagged
# Installer/default host state is rooted under `%USERPROFILE%\.mimir`
# on Windows and `$HOME/.mimir` elsewhere when MAB_DATA_ROOT is unset.
# Keep the container paths below for Docker-based runs.
# MAB_DATA_ROOT=%USERPROFILE%\.mimir
MAB_VAULT_ROOT=/data/vault/canonical
MAB_STAGING_ROOT=/data/vault/staging
MAB_SQLITE_PATH=/data/state/mimisbrunnr.sqlite
MAB_QDRANT_URL=http://127.0.0.1:6333
MAB_QDRANT_COLLECTION=mimisbrunnr_chunks
# Optional strict indexing behavior:
# MAB_QDRANT_SOFT_FAIL=true
MAB_PROVIDER_DOCKER_OLLAMA_BASE_URL=http://127.0.0.1:12434
MAB_OLLAMA_BASE_URL=http://127.0.0.1:12434
MAB_OLLAMA_EMBEDDING_MODEL=docker.io/ai/qwen3-embedding:0.6B-F16
MAB_OLLAMA_REASONING_MODEL=qwen3:4B-F16
MAB_OLLAMA_DRAFTING_MODEL=qwen3:4B-F16
MAB_EMBEDDING_PROVIDER=hash
MAB_REASONING_PROVIDER=heuristic
MAB_DRAFTING_PROVIDER=ollama
MAB_RERANKER_PROVIDER=ollama
# Optional strict provider behavior:
# MAB_DISABLE_PROVIDER_FALLBACKS=false
MAB_ROLE_CODING_PRIMARY_PROVIDER=docker_ollama
MAB_ROLE_CODING_PRIMARY_MODEL=qwen3-coder
MAB_ROLE_CODING_PRIMARY_TEMPERATURE=0
MAB_ROLE_CODING_PRIMARY_SEED=42
MAB_ROLE_MIMISBRUNNR_PRIMARY_PROVIDER=docker_ollama
MAB_ROLE_MIMISBRUNNR_PRIMARY_MODEL=qwen3:4B-F16
MAB_ROLE_MIMISBRUNNR_PRIMARY_TEMPERATURE=0
MAB_ROLE_MIMISBRUNNR_PRIMARY_SEED=42
MAB_ROLE_EMBEDDING_PRIMARY_PROVIDER=docker_ollama
MAB_ROLE_EMBEDDING_PRIMARY_MODEL=docker.io/ai/qwen3-embedding:0.6B-F16
MAB_ROLE_RERANKER_PRIMARY_PROVIDER=docker_ollama
MAB_ROLE_RERANKER_PRIMARY_MODEL=qwen3-reranker
MAB_ROLE_RERANKER_PRIMARY_TEMPERATURE=0
MAB_ROLE_RERANKER_PRIMARY_SEED=42
MAB_ROLE_CODING_ADVISORY_PROVIDER=disabled
MAB_ROLE_PAID_ESCALATION_PROVIDER=disabled
# Optional OpenAI-compatible paid escalation path:
# MAB_PROVIDER_PAID_ESCALATION_BASE_URL=https://your-paid-provider.example/v1/
# MAB_PROVIDER_PAID_ESCALATION_API_KEY=replace-me
# MAB_ROLE_PAID_ESCALATION_PROVIDER=paid_openai_compat
# MAB_ROLE_PAID_ESCALATION_MODEL=your-paid-model-id
# Optional VoltAgent paid-model path with Claude fallback:
# OPENAI_API_KEY=replace-me
# ANTHROPIC_API_KEY=replace-me
# MAB_ROLE_PAID_ESCALATION_PROVIDER=voltagent_agent
# MAB_ROLE_PAID_ESCALATION_MODEL=openai/gpt-4.1-mini
# MAB_ROLE_PAID_ESCALATION_FALLBACK_MODEL=anthropic/claude-sonnet-4
# MAB_ROLE_CODING_ADVISORY_PROVIDER=voltagent_agent
# MAB_ROLE_CODING_ADVISORY_MODEL=openai/gpt-4.1-mini
# MAB_ROLE_CODING_ADVISORY_FALLBACK_MODEL=anthropic/claude-sonnet-4
MAB_CODING_RUNTIME_PYTHON_EXECUTABLE=py
MAB_CODING_RUNTIME_PYTHONPATH=./runtimes
MAB_CODING_RUNTIME_MODULE=local_experts.bridge
MAB_CODING_RUNTIME_TIMEOUT_MS=120000
MAB_API_HOST=127.0.0.1
MAB_API_PORT=8080
MAB_LOG_LEVEL=info
# Optional actor-registry auth hardening:
# MAB_AUTH_MODE=enforced
# MAB_AUTH_ALLOW_ANONYMOUS_INTERNAL=true
# MAB_AUTH_ACTOR_REGISTRY_PATH=./config/actor-registry.json
# MAB_AUTH_ISSUER_SECRET=replace-me-with-a-long-random-secret
# MAB_AUTH_ISSUED_TOKEN_REQUIRE_REGISTRY_MATCH=true
# MAB_AUTH_REVOKED_ISSUED_TOKEN_IDS_PATH=./config/revoked-issued-token-ids.json
# MAB_AUTH_REVOKED_ISSUED_TOKEN_IDS_JSON={"tokenIds":["replace-issued-token-id"]}
# Optional inline override or local-only patch over the file-backed registry:
# MAB_AUTH_ACTOR_REGISTRY_JSON=[{"actorId":"mimir-api-operator","actorRole":"operator","authTokens":[{"token":"replace-me","label":"primary","validFrom":"2026-04-04T00:00:00Z"}],"source":"mimir-api","allowedTransports":["http"],"allowedCommands":["query_history","promote_note"]}]
# Optional fixed MCP session actor. If set, the stdio MCP server uses this
# identity by default instead of requiring per-call actor fields.
# MAB_MCP_DEFAULT_ACTOR_ID=docker-mcp-session
# MAB_MCP_DEFAULT_ACTOR_ROLE=operator
# MAB_MCP_DEFAULT_ACTOR_AUTH_TOKEN=replace-with-session-token
# MAB_MCP_DEFAULT_SOURCE=mimir-mcp-session
# Optional toolbox session handoff defaults for reconnect or fork flows.
# Approved toolbox activation now returns a handoff payload that can be mapped
# into these variables for CLI or MCP sessions.
# MAB_TOOLBOX_ACTIVE_PROFILE=docs-research
# MAB_TOOLBOX_CLIENT_ID=codex
# MAB_TOOLBOX_SESSION_MODE=toolbox-activated
# MAB_TOOLBOX_SESSION_POLICY_TOKEN=replace-with-issued-toolbox-lease
# For the full Docker MCP session profile, start from:
# docker/mimir-mcp-session.env.example
